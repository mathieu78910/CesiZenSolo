# ─── Contrôle de version ──────────────────────────────────────────────────────
# L'historique Git peut peser plusieurs Mo inutilement dans le contexte de build
.git/
.gitignore

# ─── Dépendances ──────────────────────────────────────────────────────────────
# Toutes les node_modules sont reconstituées via `npm ci` dans l'image
**/node_modules/

# ─── Build outputs ────────────────────────────────────────────────────────────
# Les artefacts compilés sont générés pendant le build Docker, pas avant
**/dist/
**/build/

# ─── Fichiers d'environnement ─────────────────────────────────────────────────
# Jamais de secrets intégrés dans l'image Docker
**/.env
**/.env.local
**/.env.*.local
.env.prod
.env.prod.example

# ─── Logs ─────────────────────────────────────────────────────────────────────
**/*.log
**/logs/

# ─── OS & IDE ─────────────────────────────────────────────────────────────────
.DS_Store
**/.DS_Store
Thumbs.db
.vscode/
.idea/

# ─── Application mobile ───────────────────────────────────────────────────────
# L'app Expo/React Native n'est pas conteneurisée
mobile/

# ─── Documentation & CI ───────────────────────────────────────────────────────
docs/
.github/

# ─── Cache & Python ───────────────────────────────────────────────────────────
**/.cache/
**/__pycache__/
**/*.pyc
**/coverage/
